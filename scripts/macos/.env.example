# Copy to scripts/macos/.env (gitignored) and fill in. The scripts also read a
# repo-root .env if present. NEVER commit real secrets.

# ---- Code signing: Developer ID Application certificate ----
# Provide the certificate either as a .p12 file on disk...
APPLE_CERTIFICATE_P12="/absolute/path/to/DeveloperIDApplication.p12"
# ...or base64-encoded (handy for CI secrets):  base64 -i cert.p12 | pbcopy
# APPLE_CERTIFICATE_P12_BASE64=""
APPLE_CERTIFICATE_PASSWORD="your-p12-password"

# Optional: name the signing identity explicitly to skip auto-detection.
# List installed identities with:  security find-identity -v -p codesigning
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# ---- Notarization: App Store Connect API key ----
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"
APPLE_API_KEY_ID="XXXXXXXXXX"                              # the Key ID
APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"    # the Issuer ID

# ---- Optional: locate the Tauri bundle ----
# Default is target/release/bundle. For an x86_64 cross build, set:
# TARGET_TRIPLE="x86_64-apple-darwin"
# Or point straight at a bundle dir:
# BUNDLE_DIR="/abs/path/to/target/release/bundle"
