{
  "version": "6",
  "catalogId": "maestro-canvas/v1",
  "description": "Render interactive UI inline by writing canvas messages as ```maestro-canvas code fences in your response.",
  "protocol": {
    "format": "Wrap each canvas message in a ```maestro-canvas code fence. One JSON object per fence. Maestro intercepts the fences and renders them; they are not shown as code blocks to the user.",
    "fenceExample": "```maestro-canvas\n{\"sessionUpdate\":\"canvas_create\",\"surfaceId\":\"s1\",\"catalogId\":\"maestro-canvas/v1\",\"title\":\"My Dashboard\"}\n```",
    "messages": [
      {
        "type": "canvas_create",
        "fields": {
          "sessionUpdate": "canvas_create",
          "surfaceId": "string",
          "catalogId": "maestro-canvas/v1",
          "title": "string"
        },
        "note": "Must be the first message for a new surfaceId.",
        "jsonSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "required": ["sessionUpdate", "surfaceId", "catalogId", "title"],
          "properties": {
            "sessionUpdate": { "type": "string", "const": "canvas_create" },
            "surfaceId": { "type": "string" },
            "catalogId": { "type": "string" },
            "title": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      {
        "type": "canvas_update",
        "fields": {
          "sessionUpdate": "canvas_update",
          "surfaceId": "string",
          "components": "array of component objects"
        },
        "note": "Components are a flat adjacency list. Each has an 'id' and 'component' type. Children are referenced by ID in a 'children' array. Repeat to add or update components.",
        "jsonSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "required": ["sessionUpdate", "surfaceId", "components"],
          "properties": {
            "sessionUpdate": { "type": "string", "const": "canvas_update" },
            "surfaceId": { "type": "string" },
            "components": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "component"],
                "properties": {
                  "id": { "type": "string" },
                  "component": {
                    "type": "string",
                    "enum": [
                      "Column",
                      "Row",
                      "List",
                      "Card",
                      "Tabs",
                      "Modal",
                      "Divider",
                      "Text",
                      "Image",
                      "Icon",
                      "Video",
                      "AudioPlayer",
                      "Markdown",
                      "DataTable",
                      "Chart",
                      "Html",
                      "Button",
                      "TextField",
                      "CheckBox",
                      "ChoicePicker",
                      "Slider",
                      "DateTimeInput"
                    ]
                  }
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      {
        "type": "canvas_data",
        "fields": {
          "sessionUpdate": "canvas_data",
          "surfaceId": "string",
          "path": "string (JSON Pointer e.g. /rows)",
          "value": "any"
        },
        "note": "Use to provide data separately from structure. Reference in component props as the path string (e.g. 'rows': '/rows').",
        "jsonSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "required": ["sessionUpdate", "surfaceId", "path", "value"],
          "properties": {
            "sessionUpdate": { "type": "string", "const": "canvas_data" },
            "surfaceId": { "type": "string" },
            "path": { "type": "string" },
            "value": {}
          },
          "additionalProperties": false
        }
      }
    ]
  },
  "components": {
    "layout": {
      "Column": {
        "props": { "gap": "number (default 3)", "className": "string" },
        "accepts_children": true
      },
      "Row": {
        "props": {
          "gap": "number (default 3)",
          "wrap": "boolean",
          "align": "start|center|end|stretch",
          "equalWidth": "boolean (default true — children share width equally)"
        },
        "accepts_children": true
      },
      "List": {
        "props": { "items": "[{ text?: string, childId?: string }]", "ordered": "boolean" }
      },
      "Card": { "props": { "title": "string", "description": "string" }, "accepts_children": true },
      "Tabs": { "props": { "tabs": "[{ label: string, childId: string }]" } },
      "Modal": {
        "props": { "trigger": "string (button label)", "title": "string" },
        "accepts_children": true
      },
      "Divider": { "props": { "orientation": "horizontal|vertical" } }
    },
    "content": {
      "Text": {
        "props": {
          "text": "string",
          "variant": "heading|subheading|body|caption|code|label",
          "muted": "boolean"
        }
      },
      "Image": {
        "props": {
          "src": "string",
          "alt": "string",
          "width": "string|number",
          "height": "string|number"
        }
      },
      "Icon": {
        "props": {
          "name": "string (Lucide icon name e.g. 'check-circle')",
          "size": "number (default 16)"
        }
      },
      "Video": { "props": { "src": "string", "poster": "string" } },
      "AudioPlayer": { "props": { "src": "string" } },
      "Markdown": { "props": { "text": "string (markdown text)" } },
      "DataTable": {
        "props": {
          "columns": "[{ key: string, label: string, width?: string }]",
          "rows": "string (JSON Pointer path to row data e.g. /rows) or array"
        }
      },
      "Chart": {
        "props": {
          "type": "\"line\" | \"bar\" | \"area\" | \"pie\" (default: line)",
          "data": "string (JSON Pointer path to array of data objects e.g. /chartData)",
          "xKey": "string (object key used for x-axis labels or pie slice names, default: x)",
          "series": "[{ key: string, label: string, color?: string }] — each entry becomes one line/bar/area; pie uses series[0].key as the value field",
          "title": "string (optional label rendered above the chart)"
        },
        "note": "Send data with canvas_data before canvas_update. Cartesian data format: [{ xKeyValue, seriesKey: number, ... }]. Pie format: [{ xKeyValue, valueKey: number }]."
      },
      "Html": {
        "props": {
          "srcdoc": "string (full self-contained HTML/CSS/JS document)",
          "height": "number (px, default 400)",
          "title": "string (accessibility label)"
        },
        "note": "Rendered in a sandboxed iframe (allow-scripts only, no same-origin). Use for custom charts, animations, or layouts the catalog components cannot express."
      }
    },
    "input": {
      "Button": {
        "props": {
          "label": "string",
          "variant": "default|outline|ghost|destructive|secondary",
          "disabled": "boolean"
        }
      },
      "TextField": {
        "props": {
          "label": "string",
          "placeholder": "string",
          "value": "string",
          "disabled": "boolean"
        }
      },
      "CheckBox": { "props": { "label": "string", "checked": "boolean", "disabled": "boolean" } },
      "ChoicePicker": {
        "props": {
          "label": "string",
          "options": "[{ value: string, label: string }]",
          "value": "string",
          "placeholder": "string",
          "disabled": "boolean"
        }
      },
      "Slider": {
        "props": {
          "label": "string",
          "min": "number",
          "max": "number",
          "step": "number",
          "value": "number",
          "disabled": "boolean"
        }
      },
      "DateTimeInput": {
        "props": {
          "label": "string",
          "variant": "date|time|datetime-local",
          "value": "string",
          "disabled": "boolean"
        }
      }
    }
  },
  "example": {
    "description": "Stats dashboard with a table — write these fences in your response text",
    "messages": [
      "```maestro-canvas\n{\"sessionUpdate\":\"canvas_create\",\"surfaceId\":\"s1\",\"catalogId\":\"maestro-canvas/v1\",\"title\":\"Summary\"}\n```",
      "```maestro-canvas\n{\"sessionUpdate\":\"canvas_update\",\"surfaceId\":\"s1\",\"components\":[\n  {\"id\":\"root\",\"component\":\"Column\",\"children\":[\"heading\",\"stats\",\"table\"]},\n  {\"id\":\"heading\",\"component\":\"Text\",\"text\":\"Results\",\"variant\":\"heading\"},\n  {\"id\":\"stats\",\"component\":\"Row\",\"children\":[\"s1\",\"s2\"]},\n  {\"id\":\"s1\",\"component\":\"Card\",\"title\":\"Total\",\"children\":[\"s1v\"]},\n  {\"id\":\"s1v\",\"component\":\"Text\",\"text\":\"42\",\"variant\":\"subheading\"},\n  {\"id\":\"s2\",\"component\":\"Card\",\"title\":\"Errors\",\"children\":[\"s2v\"]},\n  {\"id\":\"s2v\",\"component\":\"Text\",\"text\":\"3\",\"variant\":\"subheading\"},\n  {\"id\":\"table\",\"component\":\"DataTable\",\"columns\":[{\"key\":\"name\",\"label\":\"Name\"},{\"key\":\"status\",\"label\":\"Status\"}],\"rows\":\"/rows\"}\n]}\n```",
      "```maestro-canvas\n{\"sessionUpdate\":\"canvas_data\",\"surfaceId\":\"s1\",\"path\":\"/rows\",\"value\":[[\"auth.rs\",\"Pass\"],[\"db.rs\",\"Fail\"]]}\n```"
    ]
  }
}
