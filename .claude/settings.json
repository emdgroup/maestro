{
  "plansDirectory": "./.claude/plans",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm format:fix 2>/dev/null || true; output=$(pnpm lint:fix 2>&1); code=$?; [ $code -ne 0 ] && { echo \"$output\"; exit 2; }; exit 0",
            "timeout": 60,
            "asyncRewake": true,
            "statusMessage": "Formatting and linting..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
