{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        { "type": "json", "path": "src-tauri/tauri.conf.json", "jsonpath": "$.version" },
        { "type": "toml", "path": "src-tauri/Cargo.toml", "jsonpath": "$.package.version" },
        { "type": "toml", "path": "maestro-server/Cargo.toml", "jsonpath": "$.package.version" },
        { "type": "toml", "path": "maestro-protocol/Cargo.toml", "jsonpath": "$.package.version" }
      ]
    }
  }
}
